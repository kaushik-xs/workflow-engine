{
  "info": {
    "name": "Workflow Engine API",
    "description": "REST API for the workflow execution engine. Optional header: X-Tenant-ID (UUID) to scope workflows by tenant. Variables: `base_url`, `workflow_id`, `execution_id`, `tenant_id`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" },
    { "key": "workflow_id", "value": "", "type": "string" },
    { "key": "execution_id", "value": "", "type": "string" },
    { "key": "tenant_id", "value": "", "type": "string", "description": "Optional. Set to a tenant UUID to scope list/get/trigger by tenant; leave empty for default tenant." }
  ],
  "item": [
    {
      "name": "Workflows",
      "item": [
        {
          "name": "Create Workflow",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('workflow_id', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}", "description": "Optional. Tenant UUID; workflow is created under this tenant." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"triggerType\": \"httpTrigger\",\n  \"id\": \"sample\",\n  \"name\": \"sample\",\n  \"description\": \"This is a sample workflow\",\n  \"version\": \"1.0.0\",\n  \"data\": {\n    \"nodes\": [\n      {\n        \"id\": \"trigger-1\",\n        \"type\": \"httpTrigger\",\n        \"data\": {\n          \"method\": \"POST\",\n          \"path\": \"/trial\",\n          \"authentication\": \"bearer\"\n        }\n      },\n      {\n        \"id\": \"service-1\",\n        \"type\": \"serviceCall\",\n        \"data\": {\n          \"serviceName\": \"Authentication Service\",\n          \"operation\": \"recheck\",\n          \"serviceSlug\": \"authrs\",\n          \"method\": \"POST\",\n          \"path\": \"/api/licenses/recheck\"\n        }\n      }\n    ],\n    \"edges\": [\n      { \"source\": \"trigger-1\", \"target\": \"service-1\", \"id\": \"e1\" }\n    ]\n  }\n}"
            },
            "url": "{{base_url}}/workflows",
            "description": "Create a workflow. Optional X-Tenant-ID: workflow is created under that tenant (default tenant if omitted). Body can be full React Flow JSON or `{ \"name\", \"definition\" }`. Saves returned `id` to collection variable `workflow_id`."
          }
        },
        {
          "name": "List Workflows",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}", "description": "Optional. Tenant UUID; only workflows for this tenant are returned." }
            ],
            "url": "{{base_url}}/workflows",
            "description": "List workflows (id, name, created_at). If X-Tenant-ID is set, only that tenant's workflows are returned."
          }
        },
        {
          "name": "Get Workflow by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}", "description": "Optional. If set, returns 404 when workflow belongs to a different tenant." }
            ],
            "url": "{{base_url}}/workflows/{{workflow_id}}",
            "description": "Get a single workflow including full definition. Uses variable `workflow_id`. With X-Tenant-ID, workflow must belong to that tenant."
          }
        }
      ]
    },
    {
      "name": "Webhook",
      "item": [
        {
          "name": "Trigger Workflow (Webhook)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('execution_id', json.execution_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}", "description": "Optional. When triggering by name, lookup is scoped to this tenant; when by UUID, workflow must belong to this tenant." },
              { "key": "X-Custom-Header", "value": "example", "description": "Optional; headers are stored in Webhook context" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hello\": \"world\",\n  \"customer_name\": \"Acme Corp\"\n}"
            },
            "url": "{{base_url}}/webhook/{{workflow_id}}",
            "description": "Trigger workflow by workflow UUID or by name. Use {{workflow_id}} (UUID) or replace with a workflow name (e.g. 'sample'). Request body and headers become Webhook context. Saves returned `execution_id` to collection variable."
          }
        },
        {
          "name": "Trigger Workflow by Name",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('execution_id', json.execution_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}", "description": "Optional. Lookup by name is scoped to this tenant." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hello\": \"world\"\n}"
            },
            "url": "{{base_url}}/webhook/sample",
            "description": "Trigger workflow by name (e.g. 'sample'). With X-Tenant-ID, only workflows for that tenant are considered. If multiple workflows share the name, the most recently updated is used."
          }
        }
      ]
    },
    {
      "name": "Executions",
      "item": [
        {
          "name": "Get Execution by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}", "description": "Optional. If set, returns 404 when the execution's workflow belongs to a different tenant." }
            ],
            "url": "{{base_url}}/executions/{{execution_id}}",
            "description": "Get execution details: status, context, steps. Uses variable `execution_id`. With X-Tenant-ID, the execution's workflow must belong to that tenant."
          }
        }
      ]
    }
  ]
}
